# TMDB v4 Read Access Token (Bearer)
# Get one free at https://www.themoviedb.org/settings/api
# Copy this file to .env and fill in the token.
TMDB_BEARER_TOKEN=

# Anthropic API key — used by scripts/label_hierarchy.py to generate cluster labels
# at each level of the BERTopic-reduced hierarchy. Optional; falls back to
# c-TF-IDF labels if unset.
ANTHROPIC_API_KEY=
